{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casewise.example/schemas/citation.schema.json",
  "title": "Casewise Citation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "organization_id",
    "matter_id",
    "uploaded_file_id",
    "logical_document_id",
    "source_file_sha256",
    "pdf_page_index",
    "quoted_text",
    "extraction_method",
    "support_status",
    "verification_status"
  ],
  "properties": {
    "organization_id": { "type": "string", "minLength": 1 },
    "matter_id": { "type": "string", "minLength": 1 },
    "uploaded_file_id": { "type": "string", "minLength": 1 },
    "logical_document_id": { "type": "string", "minLength": 1 },
    "source_file_sha256": {
      "type": "string",
      "pattern": "^(sha256:)?[A-Fa-f0-9]{64}$"
    },
    "pdf_page_index": { "type": "integer", "minimum": 0 },
    "printed_page_label": { "type": ["string", "null"] },
    "paragraph_label": { "type": ["string", "null"] },
    "text_start": { "type": ["integer", "null"], "minimum": 0 },
    "text_end": { "type": ["integer", "null"], "minimum": 0 },
    "quoted_text": { "type": "string", "minLength": 1 },
    "bounding_boxes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["page_index", "x", "y", "width", "height"],
        "properties": {
          "page_index": { "type": "integer", "minimum": 0 },
          "x": { "type": "number", "minimum": 0 },
          "y": { "type": "number", "minimum": 0 },
          "width": { "type": "number", "exclusiveMinimum": 0 },
          "height": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },
    "extraction_method": {
      "enum": ["native_text", "ocr", "manual", "hybrid"]
    },
    "ocr_confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "support_status": {
      "enum": [
        "directly_supported",
        "partially_supported",
        "contradicted",
        "context_only",
        "ambiguous",
        "no_support_found"
      ]
    },
    "verification_status": {
      "enum": [
        "located",
        "source_verified",
        "support_verified",
        "human_reviewed",
        "invalid",
        "unreviewed"
      ]
    },
    "processing_version": { "type": ["string", "null"] }
  },
  "allOf": [
    {
      "if": {
        "properties": { "extraction_method": { "const": "ocr" } },
        "required": ["extraction_method"]
      },
      "then": { "required": ["ocr_confidence"] }
    },
    {
      "if": {
        "required": ["text_start", "text_end"],
        "properties": {
          "text_start": { "type": "integer" },
          "text_end": { "type": "integer" }
        }
      },
      "then": {
        "properties": {
          "text_end": { "type": "integer", "minimum": 1 }
        }
      }
    }
  ]
}
