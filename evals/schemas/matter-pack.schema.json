{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casewise.example/schemas/matter-pack.schema.json",
  "title": "Casewise Evaluation Matter Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "version",
    "title",
    "provenance",
    "permitted_use",
    "language",
    "matter_type",
    "split",
    "files",
    "annotation_status"
  ],
  "properties": {
    "pack_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]+$" },
    "version": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "provenance": {
      "enum": ["public", "synthetic", "professionally_redacted", "explicitly_consented"]
    },
    "provenance_reference": { "type": ["string", "null"] },
    "permitted_use": { "type": "string", "minLength": 1 },
    "restrictions": { "type": "array", "items": { "type": "string" } },
    "language": { "type": "string", "minLength": 2 },
    "jurisdiction_context": { "type": ["string", "null"] },
    "matter_type": { "type": "string", "minLength": 1 },
    "split": { "enum": ["development", "validation", "holdout"] },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file_id", "filename", "sha256", "media_type", "page_count"],
        "properties": {
          "file_id": { "type": "string", "minLength": 1 },
          "filename": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
          "media_type": { "type": "string", "minLength": 1 },
          "page_count": { "type": "integer", "minimum": 1 },
          "native_text_pages": { "type": "integer", "minimum": 0 },
          "ocr_pages": { "type": "integer", "minimum": 0 },
          "known_quality_issues": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "annotation_status": {
      "enum": ["not_started", "in_progress", "reviewed", "adjudicated"]
    },
    "annotation_version": { "type": ["string", "null"] },
    "reviewers": { "type": "array", "items": { "type": "string" } },
    "known_ambiguities": { "type": "array", "items": { "type": "string" } },
    "retention_or_deletion_requirements": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
